# Binaries (built by Makefile / CI). Patterns are anchored to top level
# and `bin/` so they don't accidentally swallow `cmd/agent`, `internal/server`,
# etc. — that mistake silently broke every previous release.
/agent
/server
bin/
*.exe

# Database
*.db
*.db-wal
*.db-shm

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Node
web/node_modules/

# Build output (generated by vite, embedded by go:embed)
cmd/server/web/dist/

# Config with real credentials
server.yaml
agent.yaml
!config/*.example.yaml

# Environment
.env
.env.*
